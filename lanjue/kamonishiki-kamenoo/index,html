<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho+B1:wght@500;600;700;800&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root{
  /* 加茂錦 龜之尾 50% 專屬色系：古籍米白 + 深石墨色 + 荷札黃 */
  --bg:        #E8E4D8;      /* 古籍米白 (主底色) */
  --bg2:       #F2EFE6;      /* 較亮的米白 */
  
  --dark:      #2F4F4F;      /* 深石墨色 (對比底色) */
  --dark2:     #1C3333;      /* 極深石墨色 */
  
  --nifuda:    #F5D130;      /* 標誌性荷札黃 */
  --nifuda-dk: #D4B01C;      /* 暗荷札黃 */
  
  --ink:       #1A1A1A;      /* 深黑字體 */
  --inkm:      #4A4D4A;      /* 內文灰綠黑 */
  --ink-light: #E8E4D8;      /* 亮色字體 (用於暗背景) */
  
  --line:      rgba(47,79,79,.15); /* 石墨色分隔線 */
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Noto Sans TC',sans-serif;font-weight:300;background:var(--bg);color:var(--ink);overflow-x:hidden;}

/* TICKER */
.ticker{overflow:hidden;white-space:nowrap;border-bottom:1px solid var(--line);padding:.8rem 0;background:var(--bg);}
.ticker-track{display:inline-flex;animation:tick 35s linear infinite;}
.ticker-track span{font-family:'Shippori Mincho B1',serif;font-weight:600;font-size:.85rem;letter-spacing:.25em;text-transform:uppercase;padding:0 1.4rem;color:var(--dark);}
.ticker-track span.ac{color:var(--nifuda-dk);font-style:normal;}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* HERO */
#hero{
  position:relative;width:100%;min-height:100svh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  overflow:hidden;
  background:linear-gradient(135deg, #F2EFE6 0%, #E8E4D8 60%, #D8D3C5 100%);
}

/* Dynamic Rice Ear Lines (動態稻穗抽象線條) */
.rice-lines{
  position:absolute;inset:0;z-index:0;pointer-events:none;opacity:0.6;
  background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg"><path d="M0,100 C20,70 40,90 50,50 C60,10 80,30 100,0" fill="none" stroke="rgba(47,79,79,0.05)" stroke-width="1.5"/></svg>');
  background-size: 80px 120px;
  animation:swayRice 15s ease-in-out infinite alternate;
}
@keyframes swayRice{0%{background-position:0 0;}100%{background-position:20px 30px;}}

/* Faint Carbonation (微弱碳酸氣泡感) */
.faint-bubbles{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden;}
.bubble{
  position:absolute;bottom:-5%;
  background:rgba(255,255,255,0.6);
  border-radius:50%;
  animation:riseBubble var(--dur) ease-in infinite var(--delay);
}
@keyframes riseBubble{
  0%{transform:translateY(0) scale(0.5);opacity:0;}
  20%{opacity:0.5;}
  100%{transform:translateY(-110vh) scale(1.2);opacity:0;}
}

/* Yellow Nifuda Tag (手寫感黃色荷札標籤) */
.hero-nifuda{
  position:absolute;top:40%;left:50%;
  transform:translate(-50%,-50%) rotate(3deg);
  width:clamp(120px,30vw,200px);
  height:clamp(280px,70vw,460px);
  background:var(--nifuda);
  border-radius:4px;
  box-shadow:5px 15px 30px rgba(0,0,0,0.08), inset 0 0 20px rgba(212,176,28,0.5);
  z-index:2;
  display:flex;flex-direction:column;align-items:center;justify-content:flex-start;
  padding:2rem 0;
  animation:nifudaFloat 6s ease-in-out infinite alternate;
}
.hero-nifuda::before{content:'';position:absolute;top:1rem;left:50%;transform:translateX(-50%);width:12px;height:12px;background:var(--bg);border-radius:50%;box-shadow:inset 0 2px 4px rgba(0,0,0,0.2);}
.nifuda-text{font-family:'Shippori Mincho B1',serif;font-weight:800;font-size:clamp(2rem,6vw,3.5rem);color:var(--dark2);writing-mode:vertical-rl;letter-spacing:0.3em;text-shadow:1px 1px 0 rgba(255,255,255,0.3);margin-top:2rem;}
@keyframes nifudaFloat{0%{transform:translate(-50%,-50%) rotate(3deg);}100%{transform:translate(-50%,-52%) rotate(1deg);}}

/* Spec Badge */
.spec-badge{
  position:absolute;top:2rem;right:1.6rem;z-index:4;
  display:flex;flex-direction:column;align-items:center;
  border:1px solid rgba(47,79,79,.2);
  padding:.6rem .8rem;
  background:rgba(232,228,216,.8);
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
  border-radius:2px;
}
.spec-score{font-family:'Shippori Mincho B1',serif;font-weight:700;font-size:1.5rem;color:var(--dark);line-height:1;}
.spec-label{font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:.55rem;letter-spacing:.15em;color:var(--nifuda-dk);margin-top:.3rem;text-transform:uppercase;}

/* Bottle */
.hero-bottle-full{position:relative;z-index:3;display:flex;align-items:center;justify-content:center;width:100%;padding:4rem 0 9rem;}
.hero-bottle-full img{
  width:clamp(140px,36vw,240px);height:auto;object-fit:contain;
  filter:drop-shadow(0 30px 40px rgba(47,79,79,.4));
  animation:elegantFloat 8s ease-in-out infinite alternate;
}
.bottle-ph{
  width:clamp(130px,32vw,190px);
  aspect-ratio:1/3.6;
  background:linear-gradient(170deg,#FFFFFF 0%,#D8D3C5 100%);
  border:1px solid rgba(47,79,79,.3);
  border-radius:12px 12px 4px 4px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  box-shadow:0 20px 40px rgba(47,79,79,.2);
  animation:elegantFloat 8s ease-in-out infinite alternate;
  position:relative;
  overflow:hidden;
}
.bottle-ph span{font-family:'Shippori Mincho B1',serif;font-weight:700;font-size:.8rem;letter-spacing:.15em;color:var(--dark);text-align:center;line-height:1.8;position:relative;z-index:2;}
@keyframes elegantFloat{0%{transform:translateY(0);} 100%{transform:translateY(-15px);}}

/* Name block */
.hero-name-block{
  position:absolute;bottom:0;left:0;right:0;z-index:4;
  padding:4rem 1.6rem 2.4rem;
  background:linear-gradient(transparent, rgba(232,228,216,.9) 40%, #E8E4D8 100%);
  display:flex;flex-direction:column;align-items:center;text-align:center;gap:.6rem;
}
.hname-big{font-family:'Shippori Mincho B1',serif;font-weight:800;font-size:clamp(2.5rem,11vw,5.5rem);color:var(--dark);letter-spacing:.15em;line-height:1.1;text-shadow:0 5px 20px rgba(255,255,255,.8);}
.hname-row{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:.5rem 1rem;padding-top:.8rem;border-top:1px solid rgba(47,79,79,.15);}
.hname-jp{font-family:'Shippori Mincho B1',serif;font-weight:600;font-size:clamp(.8rem,3.2vw,1.05rem);letter-spacing:.25em;color:var(--inkm);}
.hname-en{font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:clamp(.8rem,3.2vw,1.05rem);letter-spacing:.15em;color:var(--nifuda-dk);}
.hname-sep{color:var(--nifuda-dk);font-size:.7rem;}
.hero-slogan{font-family:'Shippori Mincho B1',serif;font-weight:600;font-size:clamp(.9rem,3.8vw,1.15rem);letter-spacing:.15em;line-height:2;color:var(--dark);margin-top:.6rem;}
.hero-scroll-hint{display:flex;align-items:center;gap:.5rem;margin-top:1.2rem;font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:.65rem;letter-spacing:.25em;color:var(--inkm);text-transform:uppercase;}
.scroll-dot{width:20px;height:2px;background:var(--dark);}

/* SECTIONS */
.sec{padding:6rem 1.4rem;}
.sec-light{background:var(--bg);color:var(--ink);}
.sec-dark{background:var(--dark);color:var(--ink-light);}
.sec-dark2{background:var(--dark2);color:var(--ink-light);}
.sec+.sec{border-top:1px solid var(--line);}
.sec-dark+.sec-light{border-top:none;}

.content-wrap{max-width:680px;margin:0 auto;}
.eyebrow{display:flex;align-items:center;gap:.8rem;margin-bottom:2.5rem;}
.eyebrow h2{font-family:'Shippori Mincho B1',serif;font-weight:800;font-size:clamp(1.3rem,5vw,1.8rem);letter-spacing:.15em;}
.sec-light .eyebrow h2{color:var(--dark);}
.sec-dark .eyebrow h2{color:var(--bg2);}
.eyebrow span{color:var(--nifuda);font-weight:400;font-size:1.2rem;}

/* ABOUT (DARK) */
.about-body p{font-family:'Noto Sans TC',sans-serif;font-weight:300;font-size:clamp(.9rem,3.5vw,1.05rem);line-height:2.8;letter-spacing:.1em;color:rgba(232,228,216,.9);margin-bottom:1.8rem;}
.about-body p:last-child{margin-bottom:0;}
.about-body p strong{color:var(--nifuda);font-weight:500;}
.photo-row{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin:3rem 0;}
.photo-box{border-radius:2px;overflow:hidden;aspect-ratio:3/4;position:relative;background:var(--dark2);border:1px solid rgba(232,228,216,.1);}
.photo-box img{width:100%;height:100%;object-fit:cover;filter:sepia(0.1) contrast(1.1) brightness(0.9);transition:transform 1.2s ease, filter 1.2s;}
.photo-box:hover img{transform:scale(1.05); filter:sepia(0) contrast(1.1) brightness(1.1);}
.photo-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;opacity:0.8;}

/* SPECS (LIGHT) */
.ring-wrap{display:flex;align-items:center;justify-content:center;margin-bottom:2.5rem;}
.ring-chart{position:relative;width:clamp(140px,40vw,180px);height:clamp(140px,40vw,180px);}
.ring-chart svg{width:100%;height:100%;filter:drop-shadow(0 5px 15px rgba(47,79,79,.1));}
.ring-val{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:'Shippori Mincho B1',serif;font-weight:800;font-size:clamp(2.5rem,8vw,3.2rem);color:var(--dark);text-shadow:0 2px 10px rgba(255,255,255,.5);}
.ring-val span{font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:.65rem;letter-spacing:.15em;color:var(--nifuda-dk);margin-top:.2rem;text-transform:uppercase;}
.spec-table{width:100%;border-collapse:collapse;}
.spec-table tr{border-bottom:1px solid var(--line);}
.spec-table td{padding:1.5rem 0;vertical-align:top;}
.spec-table td:first-child{font-family:'Shippori Mincho B1',serif;font-weight:700;font-size:.85rem;letter-spacing:.15em;color:var(--dark);width:32%;padding-top:1.6rem;}
.spec-table td:last-child{font-family:'Noto Sans TC',sans-serif;font-size:.95rem;font-weight:300;line-height:2;color:var(--inkm);}
.tags{display:flex;flex-wrap:wrap;gap:.6rem;margin-top:2.5rem;}
.tag{border:1px solid var(--dark);color:var(--dark);font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:.8rem;letter-spacing:.12em;padding:.4rem 1.2rem;transition:all .3s;cursor:default;border-radius:100px;background:transparent;}
.tag:hover{background:var(--dark);color:var(--bg2);}

/* SENSORY (DARK) */
.spotify-label{font-family:'Noto Sans TC',sans-serif;font-weight:300;font-size:.95rem;letter-spacing:.15em;color:var(--nifuda);margin-bottom:2rem;display:flex;align-items:center;gap:.6rem;}
.food-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;margin-top:1.5rem;}
.food-box{border-radius:2px;overflow:hidden;position:relative;aspect-ratio:3/4;background:var(--dark2);border:1px solid rgba(245,209,48,.15);}
.food-box img{width:100%;height:100%;object-fit:cover;filter:contrast(1.1) brightness(.9);transition:transform 1s, filter 1s;}
.food-box:hover img{transform:scale(1.05); filter:contrast(1.1) brightness(1.05);}
.food-lbl{position:absolute;bottom:0;left:0;right:0;padding:1.2rem .8rem;background:linear-gradient(transparent,rgba(28,51,51,.95));font-family:'Shippori Mincho B1',serif;font-weight:600;font-size:.85rem;letter-spacing:.15em;color:var(--bg);text-align:center;}
.food-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3.5rem;opacity:0.8;}

/* INSIGHT (LIGHT) */
#insight{background:var(--bg);padding:8rem 1.4rem;position:relative;overflow:hidden;border-top:1px solid var(--line);}
#insight::before{content:'龜';position:absolute;right:0;top:50%;transform:translateY(-50%);font-family:'Shippori Mincho B1',serif;font-weight:800;font-size:clamp(16rem,60vw,30rem);color:rgba(47,79,79,.04);pointer-events:none;line-height:1;}
.i-q{position:relative;z-index:1;font-family:'Shippori Mincho B1',serif;font-weight:600;font-size:clamp(1.05rem,4vw,1.35rem);line-height:2.8;letter-spacing:.15em;color:var(--dark);}
.i-q em{font-family:'Noto Sans TC',sans-serif;font-weight:700;font-style:normal;color:var(--nifuda-dk);font-size:1.1em;letter-spacing:.1em;}

/* FOOTER (DARK) */
#footer{background:linear-gradient(170deg,var(--dark) 0%,#111111 100%);padding:6rem 1.4rem 4rem;color:var(--ink-light);}
.f-big{font-family:'Shippori Mincho B1',serif;font-weight:800;font-size:clamp(2.8rem,13vw,6.5rem);line-height:.92;letter-spacing:.05em;color:var(--bg2);margin-bottom:.15em;}
.f-big .ac{color:var(--nifuda);}
.f-venues{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;border-top:1px solid rgba(232,228,216,.15);border-bottom:1px solid rgba(232,228,216,.15);padding:1.6rem 0;margin:2.5rem 0;}
.f-venue-item{display:flex;flex-direction:column;gap:.4rem;padding:.6rem;border-right:1px solid rgba(232,228,216,.15);}
.f-venue-item:last-child{border-right:none;}
.f-venue-date{font-family:'Noto Sans TC',sans-serif;font-weight:700;font-size:clamp(1.1rem,4vw,1.6rem);letter-spacing:.05em;color:var(--nifuda);}
.f-venue-name{font-family:'Noto Sans TC',sans-serif;font-weight:300;font-size:clamp(.8rem,3vw,1rem);letter-spacing:.1em;color:var(--ink-light);line-height:1.6;}
@media(max-width:600px){
  .f-venues{grid-template-columns:1fr;gap:0;}
  .f-venue-item{flex-direction:row;align-items:center;justify-content:space-between;border-right:none;border-bottom:1px solid rgba(232,228,216,.15);padding:1.2rem .4rem;}
  .f-venue-item:last-child{border-bottom:none;}
  .f-venue-date{min-width:3.5rem;}
  .f-venue-name{flex:1;padding:0 .8rem;}
}
.venue-follow{display:inline-block;font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:.7rem;letter-spacing:.15em;color:var(--dark);background:var(--nifuda);text-decoration:none;padding:.4rem 1.2rem;border-radius:2px;margin-top:.3rem;transition:all .3s;}
.venue-follow:hover{background:var(--bg2);transform:translateY(-2px);box-shadow:0 4px 12px rgba(245,209,48,.3);}
@media(max-width:600px){.venue-follow{margin-top:0;white-space:nowrap;}}

.f-btns{display:flex;flex-direction:column;gap:1.2rem;max-width:400px;}
.btn-fill{display:block;text-align:center;padding:1.2rem 1.4rem;font-family:'Noto Sans TC',sans-serif;font-weight:700;font-size:.95rem;letter-spacing:.2em;text-decoration:none;border:none;cursor:pointer;transition:all .3s;border-radius:2px;}
.btn-fill.primary{background:var(--nifuda);color:var(--dark);}
.btn-fill.primary:hover{background:var(--bg2);box-shadow:0 10px 20px rgba(245,209,48,.2);}
.btn-fill.dark{background:rgba(255,255,255,.05);color:var(--bg2);border:1px solid rgba(255,255,255,.2);}
.btn-fill.dark:hover{background:rgba(255,255,255,.1);color:var(--nifuda);}
.btn-fill.outline{background:transparent;color:var(--nifuda);border:1.5px solid var(--nifuda);}
.btn-fill.outline:hover{background:var(--nifuda);color:var(--dark);}

.f-fine{margin-top:4rem;padding-top:1.5rem;border-top:1px solid rgba(232,228,216,.15);display:flex;flex-wrap:wrap;justify-content:space-between;gap:.8rem;align-items:flex-end;}
.f-brand{font-family:'Noto Sans TC',sans-serif;font-weight:500;font-size:.85rem;letter-spacing:.15em;color:rgba(232,228,216,.5);}
.f-nav{display:flex;gap:1.5rem;list-style:none;}
.f-nav a{font-family:'Noto Sans TC',sans-serif;font-weight:400;font-size:.75rem;letter-spacing:.15em;color:rgba(232,228,216,.6);text-decoration:none;text-transform:uppercase;transition:color .2s;}
.f-nav a:hover{color:var(--nifuda);}

/* PARTNER & LEGAL */
.partner-bar{background:#000000;display:flex;align-items:center;justify-content:center;gap:clamp(1.5rem,5vw,4rem);padding:2rem 1.4rem;border-top:1px solid rgba(255,255,255,.05);}
.partner-logo{display:flex;align-items:center;opacity:.4;transition:all .3s;flex-shrink:0;}
.partner-logo:hover{opacity:1;transform:scale(1.1);}
.partner-logo img{height:clamp(14px,2.5vw,22px);width:auto;filter:brightness(0) invert(1);}
@media(max-width:480px){.partner-bar{gap:clamp(1rem,4vw,2rem);padding:1.5rem .8rem;flex-wrap:wrap;}.partner-logo img{height:12px;}}
.legal-bar{background:#000000;color:rgba(255,255,255,.2);text-align:center;padding:1.2rem 1.4rem;font-family:'Noto Sans TC',sans-serif;font-weight:300;font-size:.65rem;letter-spacing:.15em;line-height:2.2;}

/* DESKTOP RWD */
@media(min-width:800px){
  .sec{padding:7rem 2rem;}
  #insight{padding:9rem 2rem;}
  #footer{padding:8rem 2rem 5rem;}
}
</style>
</head>
