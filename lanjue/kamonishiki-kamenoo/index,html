<script>
// 動態生成微弱碳酸氣泡
document.addEventListener("DOMContentLoaded", () => {
  const container = document.getElementById('bubbleCanvas');
  if(!container) return;
  const bubbleCount = 15; 
  for(let i=0; i<bubbleCount; i++){
    const size = Math.random() * 6 + 2; // 2px to 8px
    const startX = Math.random() * 80 + 10; // 10% to 90% left
    const dur = Math.random() * 4 + 4; // 4s to 8s
    const delay = Math.random() * 5; 
    
    const bubble = document.createElement('div');
    bubble.className = 'bubble';
    bubble.style.width = `${size}px`;
    bubble.style.height = `${size}px`;
    bubble.style.left = `${startX}%`;
    bubble.style.setProperty('--dur', `${dur}s`);
    bubble.style.setProperty('--delay', `${delay}s`);
    
    container.appendChild(bubble);
  }
});
</script>

