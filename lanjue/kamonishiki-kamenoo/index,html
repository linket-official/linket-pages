  </div>
</div>

<!-- §1 HERO -->
<section id="hero">
  <!-- Dynamic Rice Ear Lines -->
  <div class="rice-lines"></div>

  <!-- Faint Carbonation Bubbles -->
  <div class="faint-bubbles" id="bubbleCanvas">
    <!-- Generated via JS -->
  </div>

  <!-- Yellow Nifuda Tag Anchor -->
  <div class="hero-nifuda">
    <div class="nifuda-text">龜之尾</div>
  </div>

  <!-- Spec Badge -->
  <div class="spec-badge">
    <div class="spec-score">15%</div>
    <div class="spec-label">Alc / Vol</div>
  </div>

  <!-- Bottle -->
  <div class="hero-bottle-full">
    <img src="/lanjue/kamonishiki-kamenoo/kamonishiki-bottle.png" alt="加茂錦 荷札酒 龜之尾" loading="eager"
